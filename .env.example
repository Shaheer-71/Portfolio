# ── AI Chatbot ──────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Email Notifications (Gmail) ──────────────────────────────────────────────
# Use a Gmail address + App Password (NOT your real password)
# How to get App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
OWNER_EMAIL=devshaheer360@gmail.com   # where notifications are sent to

# ── Telegram Notifications ───────────────────────────────────────────────────
# 1. Create bot: message @BotFather on Telegram → /newbot
# 2. Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# ── Google Calendar (optional) ───────────────────────────────────────────────
# 1. Go to Google Cloud Console → Create project → Enable Calendar API
# 2. Create a Service Account → Download JSON key
# 3. Share your Google Calendar with the service account email (Editor role)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary   # or your calendar's email address
